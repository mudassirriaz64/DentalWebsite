datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

generator client {
  provider = "prisma-client-js"
}

model AdminUser {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  username     String   @unique
  passwordHash String
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum SubmissionStatus {
  new
  contacted
  scheduled
  closed
}

model ContactSubmission {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  fullName        String
  serviceInterest String
  email           String
  phone           String
  whatsapp        String?
  message         String?
  status          SubmissionStatus @default(new)
  isRead          Boolean          @default(false)
  internalNote    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Service {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  shortDescription String
  description      String
  slug             String        @unique
  iconName         String
  imagePath        String?
  variant          String?       // "large-image-card" | "dark-teal-card" | "white-card" | "accent-pink-card"
  ctaLabel         String?
  bullets          String[]      // Native Mongo String array
  featured         Boolean       @default(false)
  appointments     Appointment[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Doctor {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  title        String
  specialties  String[]      // Native Mongo String array
  bio          String
  imagePath    String
  education    String[]      // Native Mongo String array
  featured     Boolean       @default(false)
  displayOrder Int           @default(0)
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum AppointmentStatus {
  pending
  confirmed
  rescheduled
  cancelled
  completed
}

model Appointment {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  patientName   String
  email         String
  phone         String
  whatsapp      String?
  serviceId     String            @db.ObjectId
  serviceTitle  String            // Write-time snapshot field
  service       Service           @relation(fields: [serviceId], references: [id])
  doctorId      String?           @db.ObjectId
  doctorName    String?           // Write-time snapshot field
  doctor        Doctor?           @relation(fields: [doctorId], references: [id])
  preferredDate DateTime?
  preferredTime String?
  notes         String?
  status        AppointmentStatus @default(pending)
  isRead        Boolean           @default(false)
  internalNote  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum ReviewStatus {
  pending
  approved
  rejected
}

model Review {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  patientName       String
  patientAvatarUrl  String?
  rating            Int          // 1-5
  title             String
  body              String
  category          String       // "Implants" | "Cosmetic" | "General Care"
  treatmentType     String?      // e.g. "Cosmetic Dentistry"
  isVerifiedPatient Boolean      @default(false)
  status            ReviewStatus @default(pending)
  featured          Boolean      @default(false)
  displayOrder      Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model SiteStat {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  page         String   // e.g. "reviews"
  label        String   // "Five Star Reviews"
  value        String   // "2,500+"
  displayOrder Int      @default(0)
  updatedAt    DateTime @updatedAt
}

enum GalleryVariant {
  comparison
  vertical
  square
  wideSplit
  small
}

enum ContentStatus {
  draft
  published
}

model GalleryItem {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  variant           GalleryVariant
  title             String
  description       String
  category          String
  beforeImageId     String?
  beforeImageUrl    String?
  beforeImageAlt    String?
  afterImageId      String?
  afterImageUrl     String?
  afterImageAlt     String?
  mainImageId       String?
  mainImageUrl      String?
  mainImageAlt      String?
  tags              String?        // comma-separated or JSON string
  isVerifiedPatient Boolean        @default(false)
  featured          Boolean        @default(false)
  status            ContentStatus  @default(draft)
  displayOrder      Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

type OpeningHoursEntry {
  label           String
  hours           String
  isEmergencyNote Boolean @default(false)
  isDimmed        Boolean @default(false)
  displayOrder    Int     @default(0)
}

model ClinicSettings {
  id               String              @id @default(auto()) @map("_id") @db.ObjectId
  address          String
  phone            String
  phoneNote        String?
  whatsapp         String?
  email            String
  emergencyPhone   String?
  mapImageUrl      String?
  mapDirectionsUrl String?
  bookingStatusMessage String?
  openingHours     OpeningHoursEntry[]
  updatedAt        DateTime            @updatedAt
}

model FounderSpotlight {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  title     String
  imagePath String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
