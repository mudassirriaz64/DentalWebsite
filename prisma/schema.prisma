datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum SubmissionStatus {
  new
  contacted
  scheduled
  closed
}

model ContactSubmission {
  id              String           @id @default(cuid())
  fullName        String
  serviceInterest String
  email           String
  phone           String
  whatsapp        String?
  message         String?
  status          SubmissionStatus @default(new)
  isRead          Boolean          @default(false)
  internalNote    String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Service {
  id               String        @id @default(uuid())
  title            String
  shortDescription String
  description      String
  slug             String        @unique
  iconName         String
  imagePath        String?
  variant          String?       // "large-image-card" | "dark-teal-card" | "white-card" | "accent-pink-card"
  ctaLabel         String?
  bulletsJson      String        @default("[]") // Serialized JSON array of strings
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Doctor {
  id              String   @id @default(uuid())
  name            String
  role            String
  title           String
  specialtiesJson String   @default("[]") // Serialized JSON array of strings
  bio             String
  imagePath       String
  educationJson   String   @default("[]") // Serialized JSON array of strings
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum ReviewStatus {
  pending
  approved
  rejected
}

model Review {
  id                String       @id @default(cuid())
  patientName       String
  patientAvatarUrl  String?
  rating            Int          // 1-5
  title             String
  body              String
  category          String       // "Implants" | "Cosmetic" | "General Care"
  treatmentType     String?      // e.g. "Cosmetic Dentistry"
  isVerifiedPatient Boolean      @default(false)
  status            ReviewStatus @default(pending)
  featured          Boolean      @default(false)
  displayOrder      Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model SiteStat {
  id           String   @id @default(cuid())
  page         String   // e.g. "reviews"
  label        String   // "Five Star Reviews"
  value        String   // "2,500+"
  displayOrder Int      @default(0)
  updatedAt    DateTime @updatedAt
}

enum GalleryVariant {
  comparison
  vertical
  square
  wideSplit
  small
}

enum ContentStatus {
  draft
  published
}

model GalleryItem {
  id                String         @id @default(cuid())
  variant           GalleryVariant
  title             String
  description       String
  category          String
  beforeImageId     String?
  beforeImageUrl    String?
  beforeImageAlt    String?
  afterImageId      String?
  afterImageUrl     String?
  afterImageAlt     String?
  mainImageId       String?
  mainImageUrl      String?
  mainImageAlt      String?
  tags              String?        // comma-separated or JSON string
  isVerifiedPatient Boolean        @default(false)
  featured          Boolean        @default(false)
  status            ContentStatus  @default(draft)
  displayOrder      Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model OpeningHoursEntry {
  id                String         @id @default(cuid())
  label             String
  hours             String
  isEmergencyNote   Boolean        @default(false)
  isDimmed          Boolean        @default(false)
  displayOrder      Int            @default(0)
  clinicSettingsId  String
  clinicSettings    ClinicSettings @relation(fields: [clinicSettingsId], references: [id], onDelete: Cascade)
}

model ClinicSettings {
  id               String              @id @default(cuid())
  address          String
  phone            String
  phoneNote        String?
  email            String
  emergencyPhone   String?
  mapImageUrl      String?
  mapDirectionsUrl String?
  openingHours     OpeningHoursEntry[]
  updatedAt        DateTime            @updatedAt
}
